<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>بثّ — لوحتي</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0A0B0F;color:#EDEDED;font-family:'Tajawal',sans-serif;min-height:100vh}

/* ===== NAV ===== */
nav{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid #1E1F26;flex-wrap:wrap;gap:12px}
.nav-logo{font-size:24px;font-weight:900;background:linear-gradient(135deg,#F2B84B,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-user{display:flex;align-items:center;gap:12px;font-size:14px;color:#8A8D96}
.nav-user strong{color:#EDEDED}
.logout-btn{background:transparent;border:1px solid #2A2C34;color:#8A8D96;border-radius:8px;padding:7px 14px;font-size:13px;font-family:'Tajawal';cursor:pointer}

main{max-width:1000px;margin:0 auto;padding:32px 20px 80px}

/* ===== STATUS BAR ===== */
.status-bar{background:#15161B;border:1px solid #1E1F26;border-radius:14px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;margin-bottom:24px}
.status-left{display:flex;align-items:center;gap:10px}
.dot{width:10px;height:10px;border-radius:50%;background:#5A5C66;flex-shrink:0}
.dot.live{background:#5FD489;box-shadow:0 0 10px #5FD48966;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
.status-text{font-size:14px;font-weight:600}
.status-sub{font-size:12px;color:#8A8D96}
.connect-btn{background:linear-gradient(135deg,#EF4444,#B91C1C);color:#fff;border:none;border-radius:10px;padding:10px 20px;font-size:14px;font-weight:700;font-family:'Tajawal';cursor:pointer}
.connect-btn.connected{background:linear-gradient(135deg,#1A3A2A,#134020);color:#5FD489;border:1px solid #5FD48944}

/* ===== رابط الستريمر ===== */
.section{margin-bottom:32px}
.section-label{font-size:12px;font-weight:700;color:#8B5CF6;letter-spacing:0.07em;margin-bottom:10px}
.section-title{font-size:20px;font-weight:800;margin-bottom:16px}

.link-card{background:#15161B;border:1px solid #1E1F26;border-radius:14px;padding:20px}
.link-desc{font-size:13px;color:#8A8D96;margin-bottom:12px;line-height:1.6}
.link-box{background:#0A0B0F;border:1px solid #2A2C34;border-radius:8px;padding:11px 14px;font-size:12.5px;color:#F2B84B;direction:ltr;word-break:break-all;margin-bottom:10px;font-family:monospace}
.copy-btn{background:#23242C;border:1px solid #2A2C34;color:#EDEDED;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:700;font-family:'Tajawal';cursor:pointer}
.copy-btn.ok{background:#1A3A2A;border-color:#5FD489;color:#5FD489}

/* ===== معرض المؤثرات ===== */
.overlays-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px}
.overlay-card{background:#15161B;border:2px solid #1E1F26;border-radius:14px;padding:18px;cursor:pointer;transition:all 0.2s;text-align:center}
.overlay-card:hover{border-color:#8B5CF6;transform:translateY(-2px)}
.overlay-card.selected{border-color:#F2B84B;background:#1A1610}
.overlay-preview{font-size:46px;margin-bottom:10px}
.overlay-name{font-size:15px;font-weight:700;margin-bottom:4px}
.overlay-desc{font-size:12px;color:#8A8D96}
.selected-badge{display:none;background:#F2B84B;color:#111;font-size:11px;font-weight:700;padding:3px 8px;border-radius:6px;margin-top:8px;display:inline-block}
.overlay-card:not(.selected) .selected-badge{display:none}

/* ===== ربط الهدايا ===== */
.gifts-list{display:flex;flex-direction:column;gap:10px}
.gift-row{background:#15161B;border:1px solid #1E1F26;border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
.gift-emoji{font-size:24px;flex-shrink:0}
.gift-info{flex:1;min-width:100px}
.gift-name{font-size:14px;font-weight:700}
.gift-id{font-size:11px;color:#5A5C66}
.gift-select{background:#0A0B0F;border:1px solid #2A2C34;border-radius:8px;padding:8px 12px;color:#EDEDED;font-size:13px;font-family:'Tajawal';min-width:160px;flex:1}
.test-btn{width:36px;height:36px;border-radius:8px;border:none;background:linear-gradient(135deg,#8B5CF6,#6D3FD8);color:#fff;font-size:14px;cursor:pointer;flex-shrink:0}

/* toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#23242C;border:1px solid #2A2C34;padding:10px 20px;border-radius:10px;font-size:13px;opacity:0;transition:opacity 0.25s;pointer-events:none;z-index:99}
.toast.show{opacity:1}
</style>
</head>
<body>

<nav>
  <div class="nav-logo">بثّ</div>
  <div class="nav-user">
    مرحباً، <strong id="navUser">...</strong>
    <button class="logout-btn" onclick="logout()">خروج</button>
  </div>
</nav>

<main>

  <!-- حالة الاتصال -->
  <div class="status-bar">
    <div class="status-left">
      <div class="dot" id="statusDot"></div>
      <div>
        <div class="status-text" id="statusText">غير متصل</div>
        <div class="status-sub" id="statusSub">اضغط "أنا Live الآن" عندما تبدأ بثك</div>
      </div>
    </div>
    <button class="connect-btn" id="connectBtn" onclick="connectLive()">🔴 أنا Live الآن</button>
  </div>

  <!-- رابط الستريمر -->
  <div class="section">
    <div class="section-label">رابطك الخاص</div>
    <div class="section-title">ضع هذا الرابط في TikTok Studio</div>
    <div class="link-card">
      <p class="link-desc">انسخ هذا الرابط وأضفه في TikTok Studio كـ "Browser Source" — المؤثر سيظهر تلقائياً على بثك عند كل هدية مربوطة</p>
      <div class="link-box" id="myLink">جاري التحميل...</div>
      <button class="copy-btn" id="copyBtn" onclick="copyLink()">📋 نسخ الرابط</button>
    </div>
  </div>

  <!-- معرض المؤثرات -->
  <div class="section">
    <div class="section-label">مكتبة المؤثرات</div>
    <div class="section-title">اختر مؤثرك المفضّل</div>
    <div class="overlays-grid" id="overlaysGrid"></div>
  </div>

  <!-- ربط الهدايا -->
  <div class="section">
    <div class="section-label">الأتمتة</div>
    <div class="section-title">اربط كل هدية بمؤثر</div>
    <div class="gifts-list" id="giftsList"></div>
  </div>

</main>

<div class="toast" id="toast"></div>

<script>
const token = localStorage.getItem("token");
const tiktokUsername = localStorage.getItem("tiktokUsername");
const username = localStorage.getItem("username");

if (!token) window.location.href = "login.html";

document.getElementById("navUser").textContent = username || "";

const SERVER = window.location.origin;
const OVERLAYS = [
  { id:"ov1", name:"قلب ذهبي متفتت", emoji:"💛", desc:"ينبض ثم يتفتت بريقاً وورداً", file:"golden-heart" },
  { id:"ov_rose", name:"وردة متطايرة", emoji:"🌹", desc:"بتلات تتطاير للأعلى بألوان زاهية", file:"rose" },
];
const GIFTS = [
  { giftId:5655, name:"وردة", emoji:"🌹" },
  { giftId:5827, name:"تاج", emoji:"👑" },
  { giftId:6064, name:"إصبع النار", emoji:"🔥" },
  { giftId:5269, name:"نجمة لامعة", emoji:"⭐" },
];

let myMapping = {};
let myOverlayChoice = "ov1";

function showToast(msg) {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(() => t.classList.remove("show"), 2200);
}

// ===== تحميل البيانات =====
async function loadMe() {
  try {
    const res = await fetch("/api/me", { headers:{"x-session-token": token} });
    if (res.status === 401) { localStorage.clear(); window.location.href = "login.html"; return; }
    const data = await res.json();
    myMapping = data.giftMapping || {};
    myOverlayChoice = data.overlayChoice || "ov1";
    renderAll();
    refreshStatus();
    setInterval(refreshStatus, 5000);
  } catch(e) { console.error(e); }
}

function renderAll() {
  // الرابط الخاص
  const overlayFile = OVERLAYS.find(o => o.id === myOverlayChoice)?.file || "golden-heart";
  const link = `${SERVER}/overlay/${overlayFile}?user=${encodeURIComponent(tiktokUsername || "")}`;
  document.getElementById("myLink").textContent = link;

  // معرض المؤثرات
  const grid = document.getElementById("overlaysGrid");
  grid.innerHTML = "";
  OVERLAYS.forEach(ov => {
    const card = document.createElement("div");
    card.className = "overlay-card" + (ov.id === myOverlayChoice ? " selected" : "");
    card.innerHTML = `
      <div class="overlay-preview">${ov.emoji}</div>
      <div class="overlay-name">${ov.name}</div>
      <div class="overlay-desc">${ov.desc}</div>
      <span class="selected-badge">✓ مختار</span>
    `;
    card.onclick = () => selectOverlay(ov.id);
    grid.appendChild(card);
  });

  // قائمة الهدايا
  const list = document.getElementById("giftsList");
  list.innerHTML = "";
  GIFTS.forEach(gift => {
    const currentOverlay = myMapping[String(gift.giftId)] || "";
    const row = document.createElement("div");
    row.className = "gift-row";
    row.innerHTML = `
      <div class="gift-emoji">${gift.emoji}</div>
      <div class="gift-info">
        <div class="gift-name">${gift.name}</div>
        <div class="gift-id">giftId: ${gift.giftId}</div>
      </div>
      <select class="gift-select" data-gift="${gift.giftId}">
        <option value="">— بدون مؤثر —</option>
        ${OVERLAYS.map(ov => `<option value="${ov.id}" ${ov.id===currentOverlay?"selected":""}>${ov.name}</option>`).join("")}
      </select>
      <button class="test-btn" data-overlay="${currentOverlay}" title="تجربة المؤثر الآن">▷</button>
    `;
    const select = row.querySelector("select");
    const testBtn = row.querySelector(".test-btn");
    select.onchange = () => { updateMapping(gift.giftId, select.value || null); testBtn.dataset.overlay = select.value; };
    testBtn.onclick = () => triggerOverlay(testBtn.dataset.overlay);
    list.appendChild(row);
  });
}

async function selectOverlay(overlayId) {
  myOverlayChoice = overlayId;
  await fetch("/api/me/overlay", { method:"POST", headers:{"Content-Type":"application/json","x-session-token":token}, body:JSON.stringify({overlayId}) });
  renderAll();
  showToast("تم اختيار المؤثر ✓");
}

async function updateMapping(giftId, overlayId) {
  myMapping[String(giftId)] = overlayId;
  if (!overlayId) delete myMapping[String(giftId)];
  await fetch("/api/me/mapping", { method:"POST", headers:{"Content-Type":"application/json","x-session-token":token}, body:JSON.stringify({giftId, overlayId}) });
  showToast("تم حفظ الربط ✓");
}

async function triggerOverlay(overlayId) {
  if (!overlayId) return showToast("اختر مؤثراً أولاً لهذه الهدية");
  await fetch("/api/trigger", { method:"POST", headers:{"Content-Type":"application/json","x-session-token":token}, body:JSON.stringify({overlayId}) });
  showToast("تم إرسال أمر التشغيل ✓");
}

function copyLink() {
  const link = document.getElementById("myLink").textContent;
  navigator.clipboard.writeText(link).then(() => {
    const btn = document.getElementById("copyBtn");
    btn.textContent = "✅ تم النسخ!";
    btn.classList.add("ok");
    setTimeout(() => { btn.textContent = "📋 نسخ الرابط"; btn.classList.remove("ok"); }, 2000);
  });
}

async function connectLive() {
  if (!tiktokUsername) return showToast("اسم TikTok غير موجود");
  const btn = document.getElementById("connectBtn");
  btn.disabled = true; btn.textContent = "جاري الاتصال...";
  try {
    await fetch("/api/connect", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({username: tiktokUsername}) });
    showToast("جاري الاتصال ببثك...");
    setTimeout(refreshStatus, 1500);
  } finally { btn.disabled = false; btn.textContent = "🔴 أنا Live الآن"; }
}

async function refreshStatus() {
  try {
    const res = await fetch("/api/status");
    const data = await res.json();
    const dot = document.getElementById("statusDot");
    const txt = document.getElementById("statusText");
    const sub = document.getElementById("statusSub");
    const btn = document.getElementById("connectBtn");
    if (data.connected && data.username === tiktokUsername) {
      dot.className = "dot live";
      txt.textContent = "متصل ببثك ✅";
      sub.textContent = `${data.overlaysConnected} صفحة مؤثر متصلة — المؤثرات تعمل تلقائياً`;
      btn.className = "connect-btn connected";
      btn.textContent = "✅ متصل";
    } else {
      dot.className = "dot";
      txt.textContent = "غير متصل";
      sub.textContent = "اضغط الزر عندما تبدأ بثك على TikTok";
      btn.className = "connect-btn";
      btn.textContent = "🔴 أنا Live الآن";
    }
  } catch(e) {}
}

function logout() {
  fetch("/api/logout", { method:"POST", headers:{"x-session-token":token} });
  localStorage.clear();
  window.location.href = "index.html";
}

loadMe();
</script>
</body>
</html>
