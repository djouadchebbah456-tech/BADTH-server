<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>بثّ — تسجيل الدخول</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0A0B0F;color:#EDEDED;font-family:'Tajawal',sans-serif;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px}
.logo{font-size:34px;font-weight:900;background:linear-gradient(135deg,#F2B84B,#8B5CF6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:6px;text-align:center}
.sub{color:#8A8D96;font-size:14px;margin-bottom:32px;text-align:center}
.card{background:#15161B;border:1px solid #1E1F26;border-radius:18px;padding:32px 28px;width:100%;max-width:420px}
.card h2{font-size:20px;font-weight:800;margin-bottom:24px}
label{display:block;font-size:13px;font-weight:700;color:#8A8D96;margin-bottom:6px}
input{width:100%;background:#0A0B0F;border:1px solid #2A2C34;border-radius:10px;padding:12px 14px;color:#EDEDED;font-size:15px;font-family:'Tajawal';margin-bottom:16px;direction:ltr}
input:focus{outline:2px solid #8B5CF6;border-color:transparent}
input::placeholder{color:#444}
.btn{width:100%;background:linear-gradient(135deg,#8B5CF6,#6D3FD8);color:#fff;border:none;border-radius:10px;padding:14px;font-size:16px;font-weight:700;font-family:'Tajawal';cursor:pointer}
.btn:disabled{opacity:0.5;cursor:default}
.error{background:#2A1010;border:1px solid #8B2020;color:#FF6B6B;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px;display:none}
.reg-link{text-align:center;margin-top:20px;font-size:13px;color:#8A8D96}
.reg-link a{color:#8B5CF6;text-decoration:none;font-weight:700}
</style>
</head>
<body>
<div class="logo">بثّ</div>
<p class="sub">مؤثرات هدايا TikTok Live</p>
<div class="card">
  <h2>تسجيل الدخول</h2>
  <div class="error" id="err"></div>
  <label>اسم المستخدم</label>
  <input id="username" type="text" placeholder="اسم مستخدمك" autocomplete="off"/>
  <label>كلمة السر</label>
  <input id="password" type="password" placeholder="كلمة السر"/>
  <button class="btn" id="loginBtn" onclick="login()">دخول</button>
  <div class="reg-link">ما عندك حساب؟ <a href="register.html">سجّل الآن مجاناً</a></div>
</div>
<script>
async function login() {
  const username = document.getElementById("username").value.trim();
  const password = document.getElementById("password").value;
  const err = document.getElementById("err");
  const btn = document.getElementById("loginBtn");
  err.style.display = "none";
  if (!username || !password) { err.textContent = "أدخل اسم المستخدم وكلمة السر"; err.style.display = "block"; return; }
  btn.disabled = true; btn.textContent = "جاري الدخول...";
  try {
    const res = await fetch("/api/login", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({username, password}) });
    const data = await res.json();
    if (!res.ok) { err.textContent = data.error; err.style.display = "block"; return; }
    localStorage.setItem("token", data.token);
    localStorage.setItem("username", data.username);
    localStorage.setItem("tiktokUsername", data.tiktokUsername);
    window.location.href = "dashboard.html";
  } catch(e) { err.textContent = "حدث خطأ، حاول مرة أخرى"; err.style.display = "block"; }
  finally { btn.disabled = false; btn.textContent = "دخول"; }
}
</script>
</body>
</html>
